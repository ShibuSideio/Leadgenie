rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // ABSOLUTE DATABASE LOCKDOWN: MULTI-TENANT THIN CLIENT ARCHITECTURE
    // -------------------------------------------------------------
    // All direct frontend Firestore polling is mathematically blocked.
    // Real-time synchronization is revoked.
    // 
    // Data ingress and egress strictly flows through the Orchestrator API Gateway
    // utilizing the Firebase Admin SDK to bypass these constraints securely.
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
